{
  "name": "feishu-bridge",
  "version": "0.1.0",
  "description": "本地智能路由层 + 飞书远程操控电脑",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node --env-file=.env --import tsx/esm src/main.ts",
    "dev": "node --env-file=.env --import tsx/esm src/main.ts",
    "build": "tsc",
    "evaluate": "tsx src/evaluateClassifier.ts"
