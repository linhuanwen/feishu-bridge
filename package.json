    "lark",
    "openclaw",
    "remote-control"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.48.0",
    "node-pty": "^1.1.0"
  }
}
